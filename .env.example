# =============================================================================
# CargoHub - All possible secrets. Copy to .env and fill in values.
# Never commit .env. Use scripts/sync-secrets-to-github.ps1 to push to GitHub.
# .NET uses double underscore for nested config: Section__Key
# =============================================================================

# ---- Database ----
ConnectionStrings__DefaultConnection=Host=localhost;Port=5433;Database=portal;Username=postgres;Password=postgres

# ---- Auth & Bootstrap ----
Bootstrap__Secret=SuperAdminBootstrapSecret
Jwt__SigningKey=PLEASE_CHANGE_ME_TO_A_LONG_SECURE_KEY
Jwt__Issuer=PortalIssuer
Jwt__Audience=PortalAudience

# ---- Portal (build-time, for Vercel/Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:5299

# ---- CORS (portal URL for API) ----
Cors__PortalOrigin=http://localhost:3000
# Self-hosted Docker (docker-compose.one / ~/.cargohub.env on runner): compose uses this host var name
# CORS__PORTAL_ORIGIN=https://your-portal.ngrok-free.app
# GitHub Actions (push-docker-mac): set NGROK_AUTHTOKEN in repo Secrets (not in .env) for automated ngrok
# For multiple origins use indexed keys:
# Cors__PortalOrigins__0=http://localhost:3000
# Cors__PortalOrigins__1=https://your-portal.vercel.app

# ---- SMTP (password reset, courier emails) ----
Smtp__Host=smtp.example.com
Smtp__Port=587
Smtp__UseSsl=true
Smtp__UserName=
Smtp__Password=
Smtp__FromAddress=noreply@example.com

# ---- DHL Express ----
Courier__DHLExpress__BaseUrl=https://express.api.dhl.com/mydhlapi
Courier__DHLExpress__UseTest=true
Courier__DHLExpress__BasicAuthBase64=
# Courier__DHLExpress__TestCreateUrl=
# Courier__DHLExpress__TestTrackingUrl=
# Courier__DHLExpress__CreateUrl=
# Courier__DHLExpress__TrackingUrl=

# ---- Matkahuolto ----
Courier__Matkahuolto__BookingUrl=https://extservicestest.matkahuolto.fi/mpaketti/mhshipmentxml

# ---- Hämeen Tavarataxi (email-based) ----
Courier__HameenTavarataxi__CarrierEmail=
Courier__HameenTavarataxi__TestEmail=

# ---- Branding (optional, usually non-secret) ----
# Branding__AppName=Portal
# Branding__LogoUrl=
# Branding__PrimaryColor=
# Branding__SecondaryColor=
# Branding__WaybillFooterText=Waybill

<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat code coverage">
        <Configuration>
          <Format>cobertura</Format>
          <!-- Exclude test project, migrations, API host, and Infrastructure (integration-heavy; Application/Domain hold the gate) -->
          <Exclude>[*.Tests]*,[*]*.Migrations*,[CargoHub.Infrastructure]*,[CargoHub.Application]*.Couriers*,[CargoHub.Api]*</Exclude>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
</RunSettings>
